APP_ENV=local
APP_URL=https://cuffmap.fesselspiel.com
PUBLIC_BASE_DOMAIN=cuffmap.fesselspiel.com
PUBLIC_TEST_PORT=8088
HTTPS_PORT=8443

POSTGRES_DB=cuffmap
POSTGRES_USER=cuffmap
POSTGRES_PASSWORD=change-me
DATABASE_URL=pgsql://cuffmap:change-me@postgres:5432/cuffmap

JWT_SECRET=change-this-to-a-long-random-secret
UPLOAD_MAX_SIZE=8388608
UPLOAD_DISK=public

SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2026-04
SHOPIFY_STOREFRONT_BASE_URL=https://fesselspiel.com
SHOPIFY_WEBHOOK_SECRET=

INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_API_VERSION=v23.0

REDIS_URL=redis://redis:6379
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://cuffmap.fesselspiel.com

LETSENCRYPT_ENABLED=false
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=true
LETSENCRYPT_TIMEOUT=180
LETSENCRYPT_WEBROOT=/var/www/certbot
LETSENCRYPT_WEBROOT_PATH=./storage/certbot
LETSENCRYPT_CERTS_PATH=./storage/letsencrypt

NEXT_PUBLIC_API_BASE_URL=http://localhost:8088/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PUBLIC_BASE_DOMAIN=cuffmap.fesselspiel.com
